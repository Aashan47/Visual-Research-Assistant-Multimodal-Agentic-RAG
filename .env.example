# LangSmith tracing (optional but recommended — set TRACING=false to disable)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=visual-research-assistant

# Ollama host (default is fine for a local install)
OLLAMA_HOST=http://localhost:11434

# Models (override only if you change the default stack)
# GENERATOR_MODEL=qwen2.5vl:7b
# CRITIQUE_MODEL=llama3.1:8b
# EMBEDDING_MODEL=nomic-embed-text

# Storage (relative paths resolve against project root)
# CHROMA_PERSIST_DIR=data/chroma_db
# DOCSTORE_DIR=data/docstore
# UPLOADS_DIR=data/uploads
# CHECKPOINTS_DB=data/checkpoints.db

# Retrieval / agent tuning
# RETRIEVAL_K=6
# MAX_RETRIES=2
# MAX_UPLOAD_MB=50
# PDF_STRATEGY=fast
